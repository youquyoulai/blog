{{ "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{ range where .Site.RegularPages "Type" "in" .Site.Params.mainSections }}
  <url>
    <loc>{{ trim .Permalink "/" }}</loc>
    <lastmod>{{ .Lastmod.Format "2006-01-02" | safeHTML }}</lastmod>
    <changefreq>{{ if .Params.changeFreq }}{{ .Params.changeFreq }}{{ else }}weekly{{ end }}</changefreq>
    <priority>{{ if .Params.priority }}{{ .Params.priority }}{{ else }}0.5{{ end }}</priority>
  </url>
  {{ end }}
</urlset>
